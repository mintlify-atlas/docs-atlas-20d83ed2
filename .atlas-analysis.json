  "keyFeatures": [
    "Invoice Management - Create, send, and track invoices with payment status",
    "Quote Management - Generate quotes and convert them to invoices",
    "Payment Processing - Record and manage customer payments with multiple payment modes",
    "Customer Relationship Management - Manage customer contacts and communication history",
    "Financial Management - Track expenses, revenue, and generate financial reports",
    "Multi-currency Support - Handle transactions in different currencies",
    "Email Integration - Send invoices and quotes via email",
    "PDF Generation - Automatically generate PDF documents for invoices and quotes",
    "Dashboard Analytics - Monitor sales performance and key business metrics",
    "User Role Management - Control access with role-based permissions"
  ],
  "publicApiSurface": [
    "POST /api/login - Authenticate admin user",
    "POST /api/logout - End admin session",
    "POST /api/invoice/create - Create new invoice",
    "GET /api/invoice/read/:id - Get invoice details",
    "PATCH /api/invoice/update/:id - Update invoice",
    "DELETE /api/invoice/delete/:id - Delete invoice",
    "GET /api/invoice/list - List invoices with pagination",
    "POST /api/invoice/mail - Send invoice via email",
    "POST /api/quote/create - Create new quote",
    "GET /api/quote/convert/:id - Convert quote to invoice",
    "POST /api/quote/mail - Send quote via email",
    "POST /api/payment/create - Record payment",
    "GET /api/payment/list - List payments",
    "POST /api/client/create - Create customer record",
    "GET /api/client/list - List all customers",
    "GET /api/setting/readBySettingKey/:settingKey - Get setting value",
    "PATCH /api/setting/updateBySettingKey/:settingKey - Update setting"
  ]
}
